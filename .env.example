# ── XRPL Wave Machine environment ─────────────────────────────
# Copy to .env (git-ignored) and fill in.

# Xaman QR sign-in — create an app at https://apps.xumm.dev
# Whitelist your origins there: http://localhost:5173 and your Vercel domain.
# The API KEY is safe in frontend code (PKCE flow).
# The API SECRET must NEVER appear here or anywhere client-side —
# it belongs only in Vercel server environment variables if you later
# add server-side Xaman payloads.
VITE_XAMAN_API_KEY=

# XRPL public WebSocket (read-only). Default is fine; swap in your own
# rippled node (Mac mini) when it's synced for zero rate-limit exposure.
VITE_XRPL_WS=wss://xrplcluster.com

# Development switch. Set to false before enabling daily spin limits.
VITE_UNLIMITED_SPINS=true

# Swag controls. These are UI defaults; enforce them server-side in production.
VITE_MONTHLY_SWAG_WINNER_LIMIT=10
VITE_SWAG_COOLDOWN_MONTHS=3
VITE_SWAG_MIN_UNIQUE_MISSIONS=3
